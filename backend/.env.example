# ============================================================
# Backend Environment Variables
# ============================================================
# Path ke model file (.pth atau .safetensors)
MODEL_PATH=./models/mammo_ai_mvp_clean.pth

# Daftar origin CORS (dipisah koma)
# Development: http://localhost:3000
# Production: https://mammo-ai.vercel.app
CORS_ORIGINS=http://localhost:3000,https://mammo-ai.vercel.app

# Environment: development | production
FASTAPI_ENV=development

# Maks upload file (50MB default)
MAX_FILE_SIZE=52428800

# Timeout inference (detik)
INFERENCE_TIMEOUT=30

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
