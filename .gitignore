# ============================================================
# Python Patterns
# ============================================================
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
venv/
env/
.venv/
.env

# ============================================================
# Node.js / Next.js Patterns
# ============================================================
# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# local env files
.env*.local
.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ============================================================
# IDE / Editor Patterns
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*.iml
.DS_Store
*.pem

# ============================================================
# Agent Instructions (local dev only)
agents.md

# ============================================================
# Logs
# ============================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*
